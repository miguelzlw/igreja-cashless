rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function role() { return getUserData().role; }
    function hasRole(r) { return isAuth() && role() == r; }
    function hasAnyRole(roles) { return isAuth() && role() in roles; }
    function isOwner(userId) { return isAuth() && uid() == userId; }
    function getUserStallId() { return getUserData().stall_id; }

    // ── Usuários ────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || hasAnyRole(['admin', 'caixa', 'gerente_barraca', 'vendedor']);
      allow create: if isOwner(userId) || hasRole('admin');
      allow update: if
        hasRole('admin') ||
        hasRole('caixa') ||
        // Gerente pode vincular/desvincular vendedores da SUA barraca
        (hasRole('gerente_barraca') &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stall_id', 'stall_name', 'role']) &&
          request.resource.data.role in ['vendedor', 'user'] &&
          request.resource.data.balance == resource.data.balance) ||
        // Usuário comum só atualiza campos que não sejam role e balance
        (isOwner(userId) &&
          request.resource.data.balance == resource.data.balance &&
          request.resource.data.role == resource.data.role);
      // Saldo só pode ser alterado via Cloud Functions (admin SDK).
    }

    // ── Transações ──────────────────────────────────────────
    // Criação e atualização de saldo acontecem exclusivamente via Cloud Functions
    // (admin SDK), que ignoram estas regras. Clientes só lêem.
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.user_id == uid() ||
        resource.data.operator_id == uid() ||
        hasAnyRole(['admin', 'caixa']) ||
        (hasRole('gerente_barraca') && resource.data.stall_id == getUserStallId())
      );
      allow create, update, delete: if hasRole('admin');
    }

    // ── Barracas ────────────────────────────────────────────
    match /stalls/{stallId} {
      allow read: if isAuth();
      allow create: if hasRole('admin');
      allow update: if
        hasRole('admin') ||
        // Gerente pode atualizar dados da SUA barraca (exceto total_sales_cents)
        (hasRole('gerente_barraca') && getUserStallId() == stallId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['total_sales_cents']));
      // total_sales_cents só é incrementado via Cloud Function (admin SDK)
      allow delete: if hasRole('admin');
    }

    // ── Produtos (subcoleção) ───────────────────────────────
    match /stalls/{stallId}/products/{productId} {
      allow read: if isAuth();
      allow create, update: if
        hasRole('admin') ||
        (hasRole('gerente_barraca') && getUserStallId() == stallId);
      // Vendedor só pode atualizar campos operacionais (estoque, contadores)
      allow update: if
        hasRole('vendedor') && getUserStallId() == stallId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['stock', 'units_sold', 'revenue_cents', 'updated_at']);
      allow delete: if
        hasRole('admin') ||
        (hasRole('gerente_barraca') && getUserStallId() == stallId);
    }

    // ── Contas Temporárias / Fichas ────────────────────────
    match /temp_accounts/{accountId} {
      allow read: if hasAnyRole(['admin', 'caixa']);
      allow create: if hasRole('caixa') || hasRole('admin');
      allow update: if hasAnyRole(['admin', 'caixa', 'vendedor']);
      allow delete: if hasRole('admin');
    }

    // ── Bloqueio padrão ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
